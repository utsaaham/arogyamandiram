# Copy to .env.local and fill in your values:
# cp .env.example .env.local

# Required - Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/arogyamandiram
MONGO_DB=arogyamandiram

# Optional - Dev server port for `npm run dev`
PORT=3000

# Required - NextAuth (use a long random string for NEXTAUTH_SECRET in production)
# If you change PORT above, update this URL to match.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-at-least-32-characters-long

# Platform tour version (increment to trigger tour updates for users)
# Note: Use only integer values for the tour version to ensure proper comparison in the code.
NEXT_PUBLIC_DASHBOARD_TOUR_VERSION=1

# Debug mode (set to true to enable debug logging in the application)
NEXT_PUBLIC_DEBUG_MODE=true

# Required - Encryption for sensitive user data
ENCRYPTION_KEY=your-32-byte-hex-string-for-aes256

# Optional - AI recommendations
OPENAI_API_KEY=sk-...

# Optional - Food search (Edamam)
EDAMAM_APP_ID=your-edamam-app-id
EDAMAM_APP_KEY=your-edamam-app-key
